<div class="trust-bar">
  <div class="page-width trust-bar__wrap">
    <div class="trust-item">
      <div class="trust-item__icon">
        <!-- Shield / secure -->
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l7 3v5c0 5-3.6 9.7-7 12-3.4-2.3-7-7-7-12V5l7-3z"/></svg>
      </div>
      <div class="trust-item__text">Compra Segura</div>
    </div>

    <div class="trust-item">
      <div class="trust-item__icon">
        <!-- Truck / shipping -->
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M3 3h13l4 4v10a1 1 0 0 1-1 1h-1a2 2 0 1 1-4 0H8a2 2 0 1 1-4 0H3V3z"/></svg>
      </div>
      <div class="trust-item__text">Envío a Chile</div>
    </div>

    <div class="trust-item">
      <div class="trust-item__icon">
        <!-- Badge / guarantee -->
        <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 2l2.4 4.9L20 8l-4 3.9L16.8 18 12 15.2 7.2 18 8 11.9 4 8l5.6-1.1L12 2z"/></svg>
      </div>
      <div class="trust-item__text">Garantía de Satisfacción</div>
    </div>
  </div>
</div>

{% schema %}
{ "name": "Trust Bar", "settings": [] }
{% endschema %}
